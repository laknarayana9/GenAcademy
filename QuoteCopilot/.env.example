# Copy to .env and fill in values. Do NOT commit .env.

# --- LLM provider keys (set the one matching your chosen models) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NEBIUS_API_KEY=

# --- Nebius Token Factory (OpenAI-compatible) base URL ---
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1

# --- Default LLM provider: anthropic | openai | nebius ---
# When LLM_PROVIDER=nebius and FAST_MODEL/STRONG_MODEL are left at the Anthropic
# defaults, Nebius-hosted Llama models are substituted automatically.
LLM_PROVIDER=anthropic

# --- Per-role model overrides (JSON object, optional) ---
# Keys: normalizer, router, enrichment, retrieval, assessor, verifier, packager, critic
# Example: {"assessor": "claude-sonnet-4-6", "router": "claude-haiku-4-5"}
AGENT_MODEL_MAP=

# --- Default models by tier (used when AGENT_MODEL_MAP omits a role) ---
FAST_MODEL=claude-haiku-4-5
STRONG_MODEL=claude-sonnet-4-6

# --- Packaging critic loop (read once at graph compile time) ---
CRITIC_ENABLED=false
CRITIC_RETRY_BUDGET=2

# --- Storage paths ---
BUSINESS_DB_PATH=./data/quotecopilot.db
CHECKPOINT_DB_PATH=./data/checkpoints.db
CHROMA_DIR=./data/chroma
BM25_INDEX_PATH=./data/bm25_index.pkl
CORPUS_DIR=./corpus

# --- Retrieval tuning ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_TOP_K=5

# --- API base used by the Streamlit client ---
API_BASE_URL=http://localhost:8000
